# =============================================================================
# Root-level .env (compose-only) - copy to .env if needed
# Most variables live in backend/.env; this file is only for shared compose
# overrides like REDIS_PASSWORD when you don't want to put it in backend/.env.
#
# !!! NEVER put real tokens here. This file is committed to git.
# !!! Real secrets go in backend/.env (which IS in .gitignore).
# =============================================================================

REDIS_PASSWORD=devpassword
LOG_LEVEL=DEBUG

# DO NOT add GITHUB_TOKEN / GROQ_API_KEY here -- they belong in backend/.env.
