# =============================================================================
# Devscope Backend - environment variables (example)
# Copy to backend/.env and fill in. NEVER commit the populated .env file.
# =============================================================================

# Server
ENVIRONMENT=development
LOG_LEVEL=DEBUG
MCP_HOST=0.0.0.0
MCP_PORT=8000

# GitHub integration
# Fine-grained PAT recommended (scopes: public repos read, user profile read).
# Classic token works with public_repo + read:user.
GITHUB_TOKEN=ghp_replace_me

# Groq (LLM streaming)
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

# Redis
# LOCAL DEV: docker-compose composes REDIS_URL from REDIS_PASSWORD below.
# Leave REDIS_URL blank locally.
REDIS_PASSWORD=devpassword
# REDIS_URL=redis://:devpassword@localhost:6379/0
#
# PRODUCTION: set REDIS_URL to your Upstash connection string.
# REDIS_URL=rediss://default:<token>@us1-XXX.upstash.io:6379

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
# TRUSTED_PROXY_DEPTH=1   # 1 = behind Railway/single load balancer (default)

# CORS (comma-separated list of allowed origins in production)
# CORS_ORIGINS=https://yourapp.netlify.app,https://yourdomain.com

# Region (informational, surfaced via /health)
DEPLOY_REGION=local
