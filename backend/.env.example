# =============================================================================
# Reporeaver Backend — environment variables (example)
# Copy to backend/.env and fill in. NEVER commit the populated .env file.
# =============================================================================

# --- MCP server -------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_TRANSPORT=streamable-http

# --- GitHub integration -----------------------------------------------------
# Personal Access Token. Fine-grained recommended (scopes: public repos read,
# user profile read). Classic token works too with `public_repo` + `read:user`.
GITHUB_TOKEN=ghp_replace_me

# --- Groq (Llama 3 streaming) -----------------------------------------------
GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.1-70b-versatile

# --- Redis ------------------------------------------------------------------
# LOCAL DEV: docker-compose builds REDIS_URL automatically from REDIS_PASSWORD
# below — leave REDIS_URL blank locally.
REDIS_PASSWORD=devpassword
# REDIS_URL=redis://:devpassword@localhost:6379/0
#
# PRODUCTION: set REDIS_URL to your Upstash connection string instead.
# REDIS_URL=rediss://default:<token>@us1-XXX.upstash.io:6379

# --- Rate limiting ----------------------------------------------------------
RATE_LIMIT_PER_MINUTE=30

# --- Region pin (informational; surfaced via /health) -----------------------
DEPLOY_REGION=local
