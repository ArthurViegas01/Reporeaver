# =============================================================================
# terraform.tfvars.example  (copy to terraform.tfvars — DO NOT COMMIT)
# -----------------------------------------------------------------------------
# Preferred: pass secrets via env vars instead of putting them in this file:
#
#   export TF_VAR_railway_token="..."
#   export TF_VAR_netlify_token="..."
#   export TF_VAR_github_token="ghp_..."
#   export TF_VAR_groq_api_key="gsk_..."
#   export TF_VAR_upstash_redis_url="rediss://default:...@us1-XXX.upstash.io:6379"
#   export TF_VAR_netlify_site_id="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
# If you must use a tfvars file, it is already in .gitignore.
# =============================================================================

project_name = "reporeaver"
environment  = "production"

# Region policy: US ONLY. São Paulo (gru) is BANNED.
# Allowed: us-west1 | us-west2 | us-east4
railway_region = "us-east4"

# --- Secrets (use TF_VAR_* env vars in real life) -----------------------------
# railway_token     = "REPLACE_ME"
# netlify_token     = "REPLACE_ME"
# github_token      = "ghp_REPLACE_ME"
# groq_api_key      = "gsk_REPLACE_ME"
# upstash_redis_url = "rediss://default:REPLACE_ME@us1-XXX.upstash.io:6379"

# --- Backend ------------------------------------------------------------------
# Public GHCR image — built by GitHub Actions later. Free for public repos.
backend_image         = "ghcr.io/arthurpviegas/reporeaver-backend:latest"
backend_cpu           = 1
backend_memory_mb     = 512 # smaller default → less Railway credit burn
backend_replicas      = 1
rate_limit_per_minute = 30
log_level             = "INFO"

# --- Frontend (Netlify) -------------------------------------------------------
# Step 1: Connect GitHub repo at app.netlify.com → "Import from Git"
#         Use base dir = frontend/, publish dir = dist/
# Step 2: Copy the Site ID from Site configuration and set it below.
netlify_site_name = "reporeaver" # becomes reporeaver.netlify.app
# netlify_site_id   = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"  # set via TF_VAR
# frontend_custom_domain = "reporeaver.example.com"
